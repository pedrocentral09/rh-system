generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String            @id @default(uuid())
  firebaseUid String?           @unique
  email       String?           @unique
  name        String?
  role        String            @default("EMPLOYEE")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  roleId      String?
  auditLogs   AuditLog[]
  storeAccess UserStoreAccess[]
  roleDef     Role?             @relation(fields: [roleId], references: [id])
  employee    Employee?
  supportMessages SupportMessage[]
  notifications   Notification[]

  @@map("core_users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("core_roles")
}

model UserStoreAccess {
  id      String @id @default(uuid())
  userId  String
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("core_user_store_access")
}

model Employee {
  id                           String                  @id @default(uuid())
  name                         String
  email                        String?                 @unique
  cpf                          String?                 @unique
  rg                           String?
  issuingBody                  String?
  rgDate                       DateTime?
  dateOfBirth                  DateTime?
  gender                       String?
  maritalStatus                String?
  pis                          String?
  ctps                         String?
  voterTitle                   String?
  placeOfBirth                 String?
  mothersName                  String?
  fathersName                  String?
  educationLevel               String?
  militaryCertificate          String?
  cnh                          String?
  phone                        String?
  landline                     String?
  photoUrl                     String?
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?
  hireDate                     DateTime?
  jobTitle                     String?
  jobRoleId                    String?
  department                   String?
  status                       String                  @default("ACTIVE")
  journeyStatus                String                  @default("ACTIVE") // ADMISSION, INTEGRATION, ACTIVE, OFFBOARDING, TERMINATED
  userId                       String?                 @unique
  createdAt                    DateTime                @default(now())
  nextEvaluationDate           DateTime?
  evaluationInterval           Int?                    // Interval in months (e.g. 3, 6, 12)
  updatedAt                    DateTime                @updatedAt
  isIncomplete                 Boolean                 @default(false)
  // CPF+PIN Authentication
  pinHash                      String?
  pinMustChange                Boolean                 @default(true)
  failedPinAttempts            Int                     @default(0)
  pinLockedUntil               DateTime?
  redemptions                  RedemptionRequest[]
  taskCompletions              TaskCompletionRequest[]
  coinTransactions             CoinTransaction[]
  disciplinaryRecords          DisciplinaryRecord[]
  onboardingProcesses          OnboardingProcess[]
  loans                        Loan[]
  payslips                     Payslip[]
  salaryAdvances               SalaryAdvance[]
  oneOnOnes                    OneOnOne[]              @relation("OneOnOneEmployee")
  oneOnOnesManaged             OneOnOne[]              @relation("OneOnOneManager")
  reviewsReceived              Review[]                @relation("Evaluated")
  reviewsGiven                 Review[]                @relation("Evaluator")
  address                      Address?
  bankData                     BankData?
  contract                     Contract?
  documents                    Document[]
  jobRole                      JobRole?                @relation(fields: [jobRoleId], references: [id])
  user                         User?                   @relation(fields: [userId], references: [id])
  employmentHistory            EmploymentHistory[]
  healthRecords                HealthData[]
  legalGuardian                LegalGuardian?
  spouse                       Spouse?
  dependents                   Dependent[]
  medicalLeaves                MedicalLeave[]
  transferHistory              TransferHistory[]
  timeRecords                  TimeRecord[]
  timeSheetClosings            TimeSheetClosing[]
  workScales                   WorkScale[]
  vacationPeriods              VacationPeriod[]
  vacationRequests             VacationRequest[]
  supportTickets               SupportTicket[]
  careerHistory               CareerHistory[]
  managedStores                Store[]                 @relation("StoreManager")

  @@index([status])
  @@index([department])
  @@index([email])
  @@map("personnel_employees")
}

model Address {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_addresses")
}

model BankData {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  bankName      String
  agency        String
  accountNumber String
  accountType   String
  pixKey        String?
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_bank_data")
}

model LegalGuardian {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  name         String
  cpf          String
  rg           String
  phone        String
  relationship String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_legal_guardians")
}

model Spouse {
  id         String    @id @default(uuid())
  employeeId String    @unique
  name       String
  cpf        String?
  rg         String?
  phone      String?
  birthDate  DateTime?
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_spouses")
}

model Dependent {
  id           String    @id @default(uuid())
  employeeId   String
  name         String
  cpf          String?
  rg           String?
  birthDate    DateTime?
  relationship String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_dependents")
}

model HealthData {
  id           String   @id @default(uuid())
  employeeId   String
  asoType      String
  lastAsoDate  DateTime @default(now())
  periodicity  Int
  observations String?
  fileUrl      String?
  targetRoleId String?
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_health_data")
}

model MedicalLeave {
  id              String   @id @default(uuid())
  employeeId      String
  type            String
  startDate       DateTime
  endDate         DateTime
  daysCount       Int
  crm             String?
  doctorName      String?
  cid             String?
  documentUrl     String
  status          String   @default("PENDING")
  submittedByType String
  submittedById   String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_medical_leaves")
}

model Contract {
  id                      String             @id @default(uuid())
  employeeId              String             @unique
  companyId               String?
  storeId                 String?
  jobRoleId               String?
  sector                  String?
  sectorId                String?
  baseSalary              Decimal
  contractType            String
  workShift               String?            @default("FULL_TIME")
  workShiftId             String?
  admissionDate           DateTime
  isExperienceContract    Boolean            @default(false)
  experienceDays          Int?
  isExperienceExtended    Boolean            @default(false)
  isExperienceExtended2   Boolean            @default(false)
  hasTransportVoucher     Boolean            @default(false)
  transportVoucherValue   Decimal?
  mealVoucherValue        Decimal?
  foodVoucherValue        Decimal?
  hasFamilySalary         Boolean            @default(false)
  familySalaryDependents  Int                @default(0)
  terminationDate         DateTime?
  terminationReason       String?
  terminationReasonId     String?
  hasInsalubrity          Boolean            @default(false)
  insalubrityLevel        Int                @default(0)
  insalubrityBase         Decimal?
  hasDangerousness        Boolean            @default(false)
  dangerousnessBase       Decimal?
  hasTrustPosition        Boolean            @default(false)
  trustPositionBase       Decimal?
  hasCashHandling         Boolean            @default(false)
  cashHandlingBase        Decimal?
  monthlyBonus            Decimal?
  otherBenefits           String?
  experienceExtensionDays Int?
  experienceExtension2Days Int?
  company                 Company?           @relation(fields: [companyId], references: [id])
  employee                Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobRole                 JobRole?           @relation(fields: [jobRoleId], references: [id])
  sectorDef               Sector?            @relation(fields: [sectorId], references: [id])
  store                   Store?             @relation(fields: [storeId], references: [id])
  terminationReasonDef    TerminationReason? @relation(fields: [terminationReasonId], references: [id])
  workShiftDef            ShiftType?         @relation(fields: [workShiftId], references: [id])

  @@map("personnel_contracts")
}

model Document {
  id                    String    @id @default(uuid())
  employeeId            String
  type                  String
  category              String    @default("ADMISSAO") // ADMISSAO, FINANCEIRO, FERIAS, AFASTAMENTO
  fileUrl               String
  fileName              String
  status                String    @default("PENDING") // PENDING, SIGNED, EXPIRED
  signatureHash         String?   // SHA-256 of metadata + file
  signatureImageUrl     String?   // Base64 or URL of the drawn signature
  signatureDate         DateTime?
  signatureIp           String?
  signatureUserAgent    String?   // Device info
  signatureLat          Float?    // Geography (optional)
  signatureLng          Float?
  signatureManifestUrl  String?   // Link to the generated PDF proof
  uploadedAt            DateTime  @default(now())
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_documents")
}

model DocumentTemplate {
  id          String   @id @default(uuid())
  title       String
  category    String   // CONTRACT, WARNING, AUTHORIZATION, PAYSLIP
  content     String   @db.Text // HTML or EditorJSON
  description String?
  variables   String[] // List of variables found in template
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("personnel_document_templates")
}

model ReportTemplate {
  id            String   @id @default(uuid())
  name          String
  description   String?
  fieldIds      String[]
  filters       Json?
  groupBy       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bi_report_templates")
}

model TransferHistory {
  id            String   @id @default(uuid())
  employeeId    String
  date          DateTime
  previousStore String
  newStore      String
  reason        String
  notes         String?
  createdAt     DateTime @default(now())
  createdBy     String?
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_transfer_history")
}

model CompanySettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("config_company")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  module     String
  resource   String
  resourceId String?
  oldData    String?
  newData    String?
  ipAddress  String?
  userAgent  String?
  userId     String?
  timestamp  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@map("config_audit_logs")
}

model Company {
  id                    String     @id @default(uuid())
  name                  String
  tradingName           String?
  cnpj                  String     @unique
  stateRegistration     String?
  municipalRegistration String?
  phone                 String?
  email                 String?
  responsible           String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  zipCode               String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  stores                Store[]
  contracts             Contract[]

  @@map("core_companies")
}

model Store {
  id                    String            @id @default(uuid())
  name                  String
  tradingName           String?
  code                  String?
  cnpj                  String?
  stateRegistration     String?
  municipalRegistration String?
  phone                 String?
  email                 String?
  responsible           String?
  companyId             String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  zipCode               String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  erpId                 String?
  company               Company?          @relation(fields: [companyId], references: [id])
  storeAccess           UserStoreAccess[]
  contracts             Contract[]
  managerId             String?
  manager               Employee?         @relation("StoreManager", fields: [managerId], references: [id])

  @@map("core_stores")
}

model JobRole {
  id          String     @id @default(uuid())
  name        String     @unique
  cbo         String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contracts     Contract[]
  employees     Employee[]
  careerLevels  CareerLevel[]
  asPreviousRole CareerHistory[] @relation("PreviousRole")
  asNewRole      CareerHistory[] @relation("NewRole")
  mandatoryDocuments MandatoryDocument[]

  @@map("config_job_roles")
}

model MandatoryDocument {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   // ADMISSION, PERIODIC, TERMINATION, TRAINING
  jobRoleId   String
  jobRole     JobRole  @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("config_mandatory_documents")
}

model CareerHistory {
  id              String   @id @default(uuid())
  employeeId      String
  previousRoleId  String?
  newRoleId       String
  changeDate      DateTime
  reason          String?
  notes           String?
  createdAt       DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  previousRole    JobRole? @relation("PreviousRole", fields: [previousRoleId], references: [id])
  newRole         JobRole  @relation("NewRole", fields: [newRoleId], references: [id])

  @@map("personnel_career_history")
}

model Sector {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contracts Contract[]

  @@map("config_sectors")
}

model TerminationReason {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contracts Contract[]

  @@map("config_termination_reasons")
}

model Holiday {
  id   String   @id @default(uuid())
  date DateTime @unique
  name String

  @@map("config_holidays")
}

model ShiftType {
  id            String      @id @default(uuid())
  name          String
  startTime     String
  endTime       String
  breakDuration Int         @default(60)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  contracts     Contract[]
  workScales    WorkScale[]

  @@map("time_shift_types")
}

model WorkScale {
  id          String     @id @default(uuid())
  date        DateTime
  employeeId  String
  shiftTypeId String?
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftType   ShiftType? @relation(fields: [shiftTypeId], references: [id])

  @@unique([employeeId, date])
  @@map("time_work_scales")
}

model EmploymentHistory {
  id              String   @id @default(uuid())
  employeeId      String
  role            String
  department      String
  store           String
  admissionDate   DateTime
  terminationDate DateTime
  reason          String
  details         String?
  createdAt       DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("personnel_employment_history")
}

model TimeClockFile {
  id         String       @id @default(uuid())
  fileName   String
  fileHash   String       @unique
  store      String?
  uploadDate DateTime     @default(now())
  status     String       @default("PROCESSING")
  errorLog   String?
  records    TimeRecord[]

  @@map("time_clock_files")
}

model TimeRecord {
  id            String         @id @default(cuid())
  fileId        String?
  pis           String
  employeeId    String?
  date          DateTime
  time          String
  nsr           String?
  originalLine  String?
  isManual      Boolean        @default(false)
  justification String?
  createdAt     DateTime       @default(now())
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  file          TimeClockFile? @relation(fields: [fileId], references: [id])

  @@unique([employeeId, date, time, nsr], name: "unique_punch")
  @@index([employeeId, date])
  @@map("time_records")
}

model TimeSheetClosing {
  id           String   @id @default(uuid())
  employeeId   String
  month        Int
  year         Int
  startDate    DateTime
  endDate      DateTime
  totalBalance Decimal
  status       String   @default("CLOSED")
  pdfUrl       String?
  closedBy     String?
  closedAt     DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("time_sheet_closings")
}

model VacationPeriod {
  id         String            @id @default(uuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  limitDate  DateTime
  vested     Boolean           @default(false)
  status     String            @default("OPEN")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requests   VacationRequest[]

  @@map("vacations_periods")
}

model VacationRequest {
  id         String         @id @default(uuid())
  periodId   String
  employeeId String
  startDate  DateTime
  endDate    DateTime
  daysCount  Int
  soldDays   Int            @default(0)
  status     String         @default("DRAFT")
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  employee   Employee       @relation(fields: [employeeId], references: [id])
  period     VacationPeriod @relation(fields: [periodId], references: [id])

  @@map("vacations_requests")
}

model PayrollPeriod {
  id             String          @id @default(uuid())
  month          Int
  year           Int
  status         String          @default("OPEN")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  imports        PayrollImport[]
  payslips       Payslip[]
  salaryAdvances SalaryAdvance[]

  @@unique([month, year])
  @@map("payroll_periods")
}

model PayrollEvent {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  type         String
  description  String?
  isSystem     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payslipItems PayslipItem[]

  @@map("payroll_events")
}

model Payslip {
  id              String        @id @default(uuid())
  periodId        String
  employeeId      String
  grossSalary     Decimal       @default(0)
  netSalary       Decimal       @default(0)
  totalAdditions  Decimal       @default(0)
  totalDeductions Decimal       @default(0)
  status          String        @default("DRAFT")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           PayslipItem[]
  employee        Employee      @relation(fields: [employeeId], references: [id])
  period          PayrollPeriod @relation(fields: [periodId], references: [id])

  @@unique([periodId, employeeId])
  @@map("payroll_payslips")
}

model PayslipItem {
  id        String       @id @default(uuid())
  payslipId String
  eventId   String
  name      String
  type      String
  reference Decimal?
  value     Decimal
  createdAt DateTime     @default(now())
  source    String       @default("AUTO")
  event     PayrollEvent @relation(fields: [eventId], references: [id])
  payslip   Payslip      @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@map("payroll_payslip_items")
}

model PayrollImport {
  id             String        @id @default(uuid())
  filename       String
  periodId       String
  type           String
  status         String
  processedCount Int           @default(0)
  totalValue     Decimal       @default(0)
  uploadedAt     DateTime      @default(now())
  period         PayrollPeriod @relation(fields: [periodId], references: [id])

  @@map("payroll_imports")
}

model PayrollSettings {
  id                String   @id @default(uuid())
  minimumWage       Decimal  @default(1412.00)
  familySalaryLimit Decimal  @default(1819.26)
  familySalaryValue Decimal  @default(62.04)
  updatedAt         DateTime @updatedAt

  @@map("payroll_settings")
}

model TaxTable {
  id        String       @id @default(uuid())
  name      String
  year      Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  brackets  TaxBracket[]

  @@unique([name, year])
  @@map("payroll_tax_tables")
}

model TaxBracket {
  id        String   @id @default(uuid())
  tableId   String
  limit     Decimal
  rate      Decimal
  deduction Decimal  @default(0)
  order     Int      @default(0)
  table     TaxTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("payroll_tax_brackets")
}

model SalaryAdvance {
  id          String        @id @default(uuid())
  employeeId  String
  periodId    String
  amount      Decimal
  description String?
  status      String        @default("PENDING")
  paymentDate DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period      PayrollPeriod @relation(fields: [periodId], references: [id])

  @@unique([employeeId, periodId])
  @@map("payroll_salary_advances")
}

model Loan {
  id                String   @id @default(uuid())
  employeeId        String
  totalAmount       Decimal
  installmentsCount Int
  reason            String?
  status            String   @default("ACTIVE")
  startDate         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  type              String   @default("ADVANCE")
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("payroll_loans")
}

model LoanInstallment {
  id                String   @id @default(uuid())
  loanId            String
  periodId          String
  installmentNumber Int
  amount            Decimal
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([loanId, periodId])
  @@map("payroll_loan_installments")
}

model ExternalImport {
  id          String   @id @default(uuid())
  employeeId  String
  periodId    String
  itemCode    String
  label       String
  amount      Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sourceStore String?

  @@unique([employeeId, periodId, itemCode, sourceStore], map: "payroll_external_imports_idx_new")
  @@map("payroll_external_imports")
}

model DisciplinaryRecord {
  id            String    @id @default(uuid())
  employeeId    String
  type          String
  severity      String
  date          DateTime
  reason        String
  description   String
  daysSuspended Int?      @default(0)
  startDate     DateTime?
  returnDate    DateTime?
  documents     String?
  payrollStatus String    @default("PENDING")
  managerId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("disciplinary_records")
}

model JobOpening {
  id             String           @id @default(uuid())
  title          String
  department     String
  description    String
  requirements   String?
  status         String           @default("DRAFT")
  type           String           @default("CLT")
  salaryRangeMin Decimal?
  salaryRangeMax Decimal?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]

  @@map("recruitment_jobs")
}

model Candidate {
  id                  String              @id @default(uuid())
  name                String
  email               String              @unique
  phone               String?
  linkedin            String?
  resumeUrl           String?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  source              String?
  onboardingProcesses OnboardingProcess[]
  applications        JobApplication[]

  @@map("recruitment_candidates")
}

model JobApplication {
  id          String     @id @default(uuid())
  jobId       String
  candidateId String
  status      String     @default("NEW")
  rating      Int?
  feedback    String?
  appliedAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  candidate   Candidate  @relation(fields: [candidateId], references: [id])
  job         JobOpening @relation(fields: [jobId], references: [id])

  @@unique([jobId, candidateId])
  @@map("recruitment_applications")
}

model OnboardingTemplate {
  id        String   @id @default(uuid())
  title     String
  items     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_templates")
}

model OnboardingProcess {
  id          String           @id @default(uuid())
  employeeId  String?
  candidateId String?
  status      String           @default("IN_PROGRESS")
  startDate   DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  candidate   Candidate?       @relation(fields: [candidateId], references: [id])
  employee    Employee?        @relation(fields: [employeeId], references: [id])
  tasks       OnboardingTask[]

  @@map("onboarding_processes")
}

model OnboardingTask {
  id          String            @id @default(uuid())
  processId   String
  title       String
  description String?
  status      String            @default("PENDING")
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  process     OnboardingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

model CareerPath {
  id          String        @id @default(uuid())
  name        String
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  levels      CareerLevel[]

  @@map("career_paths")
}

model CareerLevel {
  id           String   @id @default(uuid())
  careerPathId String
  jobRoleId    String
  order        Int
  minMonths    Int      @default(0)
  minScore     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Novas descrições do nível
  mission          String?  @db.Text
  responsibilities String?  @db.Text
  differential     String?  @db.Text

  // Regras de Automação (Limites para promoção)
  maxAbsences      Int?     // Limite de faltas permitidas
  maxDelays        Int?     // Limite de atrasos permitidos
  maxWarnings      Int?     // Limite de advertências permitidas

  path         CareerPath          @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  jobRole      JobRole             @relation(fields: [jobRoleId], references: [id])
  requirements CareerRequirement[]

  @@unique([careerPathId, order])
  @@map("career_levels")
}

model CareerRequirement {
  id            String      @id @default(uuid())
  careerLevelId String
  type          String
  description   String
  value         String?
  createdAt     DateTime    @default(now())
  level         CareerLevel @relation(fields: [careerLevelId], references: [id], onDelete: Cascade)

  @@map("career_requirements")
}

model EvaluationCycle {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  startDate DateTime  @db.Timestamp(6)
  endDate   DateTime  @db.Timestamp(6)
  isActive   Boolean?           @default(true)
  type       String?            @default("360")
  templateId String?            @db.Uuid
  createdAt  DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt  DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  reviews    Review[]
  template   EvaluationTemplate? @relation(fields: [templateId], references: [id])

  @@map("perf_eval_cycles")
}

model PerformanceAutomationSettings {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  isActive            Boolean   @default(false)
  methodology         String    @default("TOP_DOWN") // TOP_DOWN, 360, SELF
  autoCloseDays       Int       @default(15)
  checkIntervalDays   Int       @default(1)
  selectedCategories  String[]
  selectedQuestionIds String[]
  lastRun             DateTime?
  updatedAt           DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  @@map("perf_automation_settings")
}

model Review {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId     String          @db.Uuid
  evaluatorId String
  evaluatedId String
  status      String?         @default("PENDING")
  notes       String?
  totalScore  Float?
  submittedAt DateTime?       @db.Timestamp(6)
  createdAt   DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?       @default(now()) @updatedAt @db.Timestamp(6)
  answers     ReviewAnswer[]
  cycle       EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  evaluated   Employee        @relation("Evaluated", fields: [evaluatedId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evaluator   Employee        @relation("Evaluator", fields: [evaluatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("perf_reviews")
}

model ReviewQuestion {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category  String
  text      String
  weight    Float?         @default(1.0)
  isActive  Boolean?       @default(true)
  createdAt DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt DateTime?      @default(now()) @updatedAt @db.Timestamp(6)
  answers   ReviewAnswer[]
  templates EvaluationTemplate[]

  @@map("perf_review_questions")
}

model EvaluationTemplate {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  methodology String           @default("TOP_DOWN")
  description String?
  createdAt   DateTime         @default(now()) @db.Timestamp(6)
  updatedAt   DateTime         @default(now()) @updatedAt @db.Timestamp(6)
  questions   ReviewQuestion[]
  routines    EvaluationRoutine[]
  cycles      EvaluationCycle[]

  @@map("perf_evaluation_templates")
}

model EvaluationRoutine {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId        String             @db.Uuid
  name              String
  frequencyMonths   Int                @default(1)
  lastRun           DateTime?          @db.Timestamp(6)
  nextRun           DateTime?          @db.Timestamp(6)
  isActive          Boolean            @default(true)
  targetDepartments String[]
  createdAt         DateTime           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  template          EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("perf_evaluation_routines")
}

model ReviewAnswer {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId   String         @db.Uuid
  questionId String         @db.Uuid
  score      Int
  comment    String?
  createdAt  DateTime?      @default(now()) @db.Timestamp(6)
  question   ReviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  review     Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([reviewId, questionId])
  @@map("perf_review_answers")
}

model OneOnOne {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managerId   String
  employeeId  String
  date        DateTime? @default(now()) @db.Timestamp(6)
  content     String
  actionItems String?
  feeling     String?
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  employee    Employee  @relation("OneOnOneEmployee", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manager     Employee  @relation("OneOnOneManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("perf_one_on_ones")
}

model ClimateSurvey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime? @default(now()) @db.Timestamp(6)
  score      Int
  department String?
  comment    String?
  createdAt  DateTime? @default(now()) @db.Timestamp(6)

  @@map("perf_climate_surveys")
}

model CoinTransaction {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String
  amount      Int
  type        String
  source      String?
  description String
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("coins_transactions")
}

model RewardCatalog {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  cost        Int
  stock       Int?
  isActive    Boolean?            @default(true)
  imageUrl    String?
  createdAt   DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  redemptions RedemptionRequest[]

  @@map("coins_reward_catalog")
}

model RedemptionRequest {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String
  rewardId   String        @db.Uuid
  costAtTime Int
  status     String?       @default("PENDING")
  createdAt  DateTime?     @default(now()) @db.Timestamp(6)
  updatedAt  DateTime?     @default(now()) @updatedAt @db.Timestamp(6)
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reward     RewardCatalog @relation(fields: [rewardId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("coins_redemption_requests")
}

model RewardTask {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  rewardAmount Int
  isActive     Boolean?                @default(true)
  createdAt    DateTime?               @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?               @default(now()) @updatedAt @db.Timestamp(6)
  completions  TaskCompletionRequest[]

  @@map("coins_reward_tasks")
}

model TaskCompletionRequest {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String
  taskId     String     @db.Uuid
  proofText  String?
  status     String?    @default("PENDING")
  createdAt  DateTime?  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime?  @default(now()) @updatedAt @db.Timestamp(6)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task       RewardTask @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("coins_task_completions")
}

model SupportTicket {
  id          String           @id @default(uuid())
  employeeId  String
  subject     String
  status      String           @default("OPEN") // OPEN, CLOSED, IN_PROGRESS
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id])
  messages    SupportMessage[]

  @@map("portal_support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  senderId  String        // User ID
  content   String        @db.Text
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])

  @@map("portal_support_messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, URGENT
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("core_notifications")
}
